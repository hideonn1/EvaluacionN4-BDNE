# Copia este archivo a .env y ajusta tus propias credenciales
# IMPORTANTE!!: Nunca subas tu .env real al repositorio.

MONGO_DATABASE=comerciotech_db

# Administrador (root) - control total. Solo para tareas administrativas puntuales.
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CambiaEstaClaveSegura1

# Aplicación - readWrite solo sobre comerciotech_db. Identidad normal de uso del CLI.
APP_USERNAME=app_user
APP_PASSWORD=CambiaEstaClaveSegura2

# Auditor - solo lectura sobre comerciotech_db.
AUDITOR_USERNAME=auditor_user
AUDITOR_PASSWORD=CambiaEstaClaveSegura3

# Monitor - clusterMonitor sobre admin, sin acceso a datos de negocio.
MONITOR_USERNAME=monitor_user
MONITOR_PASSWORD=CambiaEstaClaveSegura4

# Parámetros de Conexión y Pooling
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_TIMEOUT_MS=5000
MONGO_USE_TLS=false
